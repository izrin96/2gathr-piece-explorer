# Copy to .env.prod and fill in real values, then:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d

# ---- Postgres passwords (self-hosted containers in docker-compose.prod.yml) ----
DB_PASSWORD=changeme
INDEXER_DB_PASSWORD=changeme

# ---- indexer (Titan L1 RPC; no archive) ----
INDEXER_RPC_ENDPOINT=https://subnets.avax.network/titan/mainnet/rpc
INDEXER_RPC_RATE_LIMIT=5
INDEXER_RPC_FINALITY=10
INDEXER_START_BLOCK=0
INDEXER_GETLOGS_RANGE=2048
INDEXER_RUBY_ADDRESS=0x16ac90358d5f8610a85fa5270659356afdc48a9e

# ---- worker (enrichment) ----
TOPPORT_BASE_URL=https://api.topport.io
